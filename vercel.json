{
  "functions": {
    "api/[...path].js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/api/[...path].js"
    },
    {
      "src": "/logout",
      "dest": "/api/[...path].js"
    },
    {
      "src": "/webhook",
      "dest": "/api/[...path].js"
    },
    {
      "src": "/healthz",
      "dest": "/api/[...path].js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
