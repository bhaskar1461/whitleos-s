{
  "functions": {
    "api/[...path].js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/logout",
      "destination": "/api/[...path]"
    },
    {
      "source": "/webhook",
      "destination": "/api/[...path]"
    },
    {
      "source": "/healthz",
      "destination": "/api/[...path]"
    }
  ]
}
